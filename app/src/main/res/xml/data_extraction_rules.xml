<?xml version="1.0" encoding="utf-8"?>
<!--
   Backup / transfer rules for Android 12 (API 31) and above.
   Same intent as backup_rules.xml: capture the Room DB + reminder DataStore so the
   user's check-ins survive cloud backup and device-to-device transfer (L4 "Soll").
-->
<data-extraction-rules>
    <cloud-backup>
        <include domain="database" path="checkin.db" />
        <include domain="file" path="datastore/checkin_settings.preferences_pb" />
    </cloud-backup>
    <device-transfer>
        <include domain="database" path="checkin.db" />
        <include domain="file" path="datastore/checkin_settings.preferences_pb" />
    </device-transfer>
</data-extraction-rules>
